{
  "name": "@southneuhof/landing-section-schema",
  "private": false,
  "version": "0.0.4",
  "type": "module",
  "description": "Section schema helpers and conventions for South Neuhof landing applications.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/southneuhof/landing-section-schema.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./common-section-meta": {
      "types": "./dist/common-section-meta.d.ts",
      "import": "./dist/common-section-meta.js"
    },
    "./defineSectionSchema": {
      "types": "./dist/defineSectionSchema.d.ts",
      "import": "./dist/defineSectionSchema.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!dist/**/*.tsbuildinfo",
    "!src/**/__tests__/**",
    "!src/**/*.spec.*",
    "!src/**/*.test.*",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@southneuhof/landing-sveltekit-framework": "workspace:^"
  },
  "devDependencies": {
    "vitest": "^2.1.9",
    "@types/node": "^18.16.16"
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:js && pnpm clean:build-info",
    "clean": "node ../../scripts/clean-package.mjs dist",
    "clean:build-info": "node ../../scripts/clean-package.mjs dist/tsconfig.build.tsbuildinfo",
    "build:js": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run"
  }
}
